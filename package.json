{
  "name": "pear-workspace",
  "private": true,
  "workspaces": ["packages/*"],
  "scripts": {
    "build": "bun run --filter @ontic/pear build && bun run --filter @ontic/pear-docs build",
    "cf:deploy": "bun run --filter @ontic/pear-docs cf:deploy",
    "cf:upload": "bun run --filter @ontic/pear-docs cf:upload",
    "preview": "bun run --filter @ontic/pear-docs preview"
  }
}
