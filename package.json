{
  "name": "pear-workspace",
  "private": true,
  "type": "module",
  "packageManager": "pnpm@11.2.2",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "build": "pnpm --filter @ontic/pear build && pnpm --filter @ontic/pear-docs build",
    "cf:deploy": "pnpm --filter @ontic/pear-docs cf:deploy",
    "cf:upload": "pnpm --filter @ontic/pear-docs cf:upload",
    "preview": "pnpm --filter @ontic/pear-docs preview",
    "prepare": "vp config"
  },
  "devDependencies": {
    "@types/node": "^25.9.1",
    "@vitest/coverage-v8": "^4.1.7",
    "happy-dom": "^20.9.0",
    "typescript": "~6.0.3",
    "vite": "npm:@voidzero-dev/vite-plus-core@^0.1.22",
    "vite-plus": "catalog:",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.22"
  }
}
