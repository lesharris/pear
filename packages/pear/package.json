{
  "name": "@ontic/pear",
  "version": "0.2.3",
  "description": "A thin Vue 3 component library built on PicoCSS",
  "type": "module",
  "main": "./dist/pear.js",
  "types": "./dist/src/index.d.ts",
  "exports": {
    ".": {
      "import": "./dist/pear.js",
      "types": "./dist/src/index.d.ts"
    },
    "./style.css": "./dist/pear.css"
  },
  "files": [
    "dist"
  ],
  "sideEffects": [
    "dist/pear.css"
  ],
  "scripts": {
    "build": "vite build",
    "build:watch": "vite build --watch",
    "type-check": "vue-tsc --build",
    "prepublishOnly": "cp ../../README.md ./README.md && pnpm run build",
    "postpublish": "rm ./README.md"
  },
  "keywords": [
    "vue",
    "vue3",
    "components",
    "ui",
    "pico",
    "picocss",
    "component-library"
  ],
  "author": "Les Harris <les@lesharris.com>",
  "license": "MIT",
  "homepage": "https://pear.ontic.cloud",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/onticcloud/pear.git"
  },
  "bugs": {
    "url": "https://github.com/onticcloud/pear/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "peerDependencies": {
    "@lucide/vue": ">=1.16.0",
    "vue": ">=3.5.34"
  },
  "devDependencies": {
    "@lucide/vue": "^1.16.0",
    "@picocss/pico": "^2.0.6",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "sass": "^1.100.0",
    "typescript": "~6.0.3",
    "vite": "^8.0.13",
    "vite-plugin-dts": "^5.0.1",
    "vue": "^3.5.34",
    "vue-tsc": "^3.2.9"
  }
}
