{
  "name": "@ontic/pear-docs",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "[ -f public/search-index.json ] || pnpm run build:search && vp dev",
    "build": "run-p type-check \"build-only {@}\" --",
    "build-only": "vp build && tsx scripts/prerender.ts",
    "build:search": "tsx scripts/prerender.ts --public",
    "type-check": "vue-tsc --build",
    "preview": "pnpm run build && wrangler dev",
    "deploy": "pnpm run build && wrangler deploy",
    "cf:deploy": "wrangler deploy",
    "cf:upload": "wrangler versions upload",
    "cf:typegen": "wrangler types"
  },
  "dependencies": {
    "@lucide/vue": "^1.16.0",
    "@ontic/pear": "workspace:*",
    "@shikijs/langs": "^4.0.2",
    "@shikijs/themes": "^4.0.2",
    "@vue/server-renderer": "^3.5.34",
    "flexsearch": "^0.8.212",
    "shiki": "^4.0.2",
    "vue": "^3.5.34",
    "vue-router": "^5.0.7"
  },
  "devDependencies": {
    "@cloudflare/vite-plugin": "^1.37.1",
    "@tsconfig/node24": "^24.0.4",
    "@types/node": "^25.8.0",
    "@vitejs/plugin-vue": "^6.0.7",
    "@vue/tsconfig": "^0.9.1",
    "npm-run-all2": "^9.0.0",
    "playwright": "^1.60.0",
    "tsx": "^4.21.0",
    "typescript": "~6.0.3",
    "vite": "catalog:",
    "vite-plugin-vue-devtools": "^8.1.2",
    "vitest": "npm:@voidzero-dev/vite-plus-test@^0.1.22",
    "vue-tsc": "^3.2.9",
    "wrangler": "^4.92.0",
    "vite-plus": "catalog:"
  }
}
